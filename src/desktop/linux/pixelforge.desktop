[Desktop Entry]
Type=Application
Name=PixelForge
GenericName=Sprite Editor
Comment=Animated sprite editor & pixel art tool
Icon=pixelforge
Categories=Graphics;2DGraphics;RasterGraphics
Exec=pixelforge %U
TryExec=pixelforge
Terminal=false
StartupNotify=false
StartupWMClass=PixelForge
MimeType=image/bmp;image/gif;image/jpeg;image/png;image/x-pcx;image/x-tga;image/vnd.microsoft.icon;video/x-flic;image/webp;image/x-pixelforge;
